# Backend Environment Variables
PORT=5000

# Database Configuration
# Supabase / PostgreSQL connection string (use Session Pooler on IPv4-only hosts like Render)
DATABASE_URL=postgresql://postgres.qpidhsjgymvjkkitmfnc:your_supabase_db_password@<session-pooler-host>:5432/postgres
DB_SSL=true

# Optional local PostgreSQL fallback
# DB_HOST=localhost
# DB_USER=postgres
# DB_PASSWORD=your_postgres_password
# DB_NAME=cessca_db
# DB_PORT=5432

# JWT Secret (Change this to a secure random string in production)
JWT_SECRET=your_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
